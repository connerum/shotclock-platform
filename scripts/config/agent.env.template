SERVER_URL=https://your-server.example.com
AGENT_LOCAL_API_PORT=3001
DEVICE_NAME=ShotClock-01
DEFAULT_DEVICE_NAME=ShotClock-01
SETUP_AP_SSID=Shotclock-Setup
SETUP_AP_PASSWORD=shotclock123
SETUP_PORTAL_HOST=sportsboard.local
# Optional: set this to the desktop login user if kiosk auto-detection fails.
# On the current Pi this is likely admin.
KIOSK_USER=
# MSD300-1 deployment default. This avoids motion artifacts/blue dots seen at
# higher Pi output resolutions while preserving correct RGB/BGR color handling.
KIOSK_DISPLAY_OUTPUT=auto
KIOSK_DISPLAY_MODE=1024x768
KIOSK_DISPLAY_RATE=60
KIOSK_HIDE_CURSOR=true
