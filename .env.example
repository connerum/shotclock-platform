# Shotclock Platform Environment Configuration

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/shotclock"

# Server
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"
SERVER_PORT="3000"

# Socket.IO
SOCKET_SERVER_URL="http://localhost:3000"

# Device Configuration
DEFAULT_DEVICE_NAME="Shotclock Display"
PAIRING_CODE_LENGTH="6"

# WiFi Configuration
SETUP_AP_SSID="Shotclock-Setup"
SETUP_AP_PASSWORD="shotclock123"
SETUP_AP_CHANNEL="6"

# Update Configuration
UPDATE_CHECK_INTERVAL="3600000"
FIRMWARE_RELEASES_PATH="/opt/shotclock/releases"

# Agent Configuration
AGENT_LOCAL_API_PORT="3001"
AGENT_HEARTBEAT_INTERVAL="30000"
